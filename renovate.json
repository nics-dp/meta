{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>nics-dp/meta:renovate-preset"],
  "github-actions": {
    "managerFilePatterns": [".github/workflows/**", "configs/codeqls/**", "golang-templates/**", "web-templates/**"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update actionlint version in reusable workflow",
      "fileMatch": ["^\\.github/workflows/actionlint\\.yml$"],
      "matchStrings": ["default:\\s*\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\"\\s*\\n\\s*description:\\s*\"actionlint version[^\"]*\""],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update quill version in go-release workflow",
      "fileMatch": ["^\\.github/workflows/go-release\\.yml$"],
      "matchStrings": ["go install github\\.com/anchore/quill/cmd/quill@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "anchore/quill",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update parlay version in SBOM workflows",
      "fileMatch": ["^\\.github/workflows/sbom-(?:source|image)\\.yml$"],
      "matchStrings": ["go install github\\.com/snyk/parlay@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "snyk/parlay",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update swag version in CodeQL configs",
      "fileMatch": ["^configs/codeqls/.+\\.yml$"],
      "matchStrings": ["go install github\\.com/swaggo/swag/cmd/swag@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "swaggo/swag",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update semgrep container image version",
      "fileMatch": ["^\\.github/workflows/(?:go|bun)-semgrep\\.yml$"],
      "matchStrings": ["image:\\s*semgrep/semgrep:(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "semgrep/semgrep",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
