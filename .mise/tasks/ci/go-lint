#!/usr/bin/env bash
#MISE description="Run golangci-lint"
#MISE raw=true

golangci-lint fmt ./...
if ! git diff --exit-code -- . >/dev/null; then
  echo "Formatting changes detected after 'golangci-lint fmt ./...'. Please run the formatter locally and commit the result."
  git diff -- . 
  exit 1
fi
golangci-lint run ./...
