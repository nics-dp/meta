{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "nics-dp org-level Renovate preset",
  "extends": [
    "config:recommended",
    ":timezone(Asia/Taipei)",
    "schedule:earlyMondays"
  ],
  "github-actions": {
    "managerFilePatterns": [".github/workflows/**", "configs/codeqls/**", "golang-templates/**", "web-templates/**"]
  },
  "packageRules": [
    {
      "description": "Group Go module updates",
      "matchManagers": ["gomod"],
      "groupName": "go dependencies",
      "commitMessagePrefix": "chore(go.deps):",
      "labels": ["dependencies", "go"],
      "automerge": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions dependencies",
      "commitMessagePrefix": "chore(ci.deps):",
      "labels": ["dependencies", "github-actions"],
      "automerge": false
    },
    {
      "description": "Group Docker updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker dependencies",
      "commitMessagePrefix": "chore(docker.deps):",
      "labels": ["dependencies", "docker"],
      "automerge": false
    },
    {
      "description": "Group npm updates",
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "commitMessagePrefix": "chore(npm.deps):",
      "labels": ["dependencies", "npm"],
      "automerge": false
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update actionlint version in reusable workflow",
      "fileMatch": ["^\\.github/workflows/actionlint\\.yml$"],
      "matchStrings": ["default:\\s*\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\"\\s*\\n\\s*description:\\s*\"actionlint version[^\"]*\""],
      "depNameTemplate": "rhysd/actionlint",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update quill version in go-release workflow",
      "fileMatch": ["^\\.github/workflows/go-release\\.yml$"],
      "matchStrings": ["go install github\\.com/anchore/quill/cmd/quill@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "anchore/quill",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update parlay version in SBOM workflows",
      "fileMatch": ["^\\.github/workflows/sbom-(?:source|image)\\.yml$"],
      "matchStrings": ["go install github\\.com/snyk/parlay@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "snyk/parlay",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update swag version in CodeQL configs",
      "fileMatch": ["^configs/codeqls/.+\\.yml$"],
      "matchStrings": ["go install github\\.com/swaggo/swag/cmd/swag@(?<currentValue>v\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "swaggo/swag",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update semgrep container image version",
      "fileMatch": ["^\\.github/workflows/(?:go|bun)-semgrep\\.yml$"],
      "matchStrings": ["image:\\s*semgrep/semgrep:(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "semgrep/semgrep",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
